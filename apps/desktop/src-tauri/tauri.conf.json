{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Desktop Todo",
  "version": "0.1.0",
  "identifier": "app.ai-desktop-todo.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Desktop Todo",
        "transparent": true,
        "decorations": false,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
